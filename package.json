{
	"name": "vike-sitemap-generator",
	"version": "0.2.0",
	"description": "Vite plugin for Vike that generates sitemap.xml at build time",
	"type": "module",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsup",
		"test": "bun test",
		"prepublishOnly": "tsup",
		"qc": "biome check .",
		"qa": "biome check . --write",
		"qau": "biome check . --write --unsafe"
	},
	"keywords": [
		"vike",
		"vite",
		"sitemap",
		"seo",
		"vite-plugin",
		"vike-plugin",
		"vike-vite-plugin"
	],
	"author": "Beau",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/welpie21/vike-sitemap-generator.git"
	},
	"peerDependencies": {
		"vike": ">=0.4.0",
		"vite": ">=5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@types/node": "^25.3.3",
		"tsup": "^8.0.0",
		"typescript": "^5.9.3",
		"vike": "^0.4.229",
		"vite": "^6.0.0"
	}
}
